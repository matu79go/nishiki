# Nishiki credentials — copy to `.env` and fill in your own values.
#
#   cp .env.example .env
#   # then write your API key after the "=" below
#
# `.env` is gitignored — NEVER commit real keys. Nishiki auto-loads `.env` from the
# working directory (and the --target / --experiment dir) at startup. A variable that
# is already set in your real environment always wins over `.env`.
#
# You only need creds for the candidate source you actually measure.

# --- OpenRouter candidates (call: openai_compatible) ---
OPENROUTER_API_KEY=        # <- paste your OpenRouter API key here (https://openrouter.ai/keys)

# --- Bedrock candidates (call: on_demand / profile) ---
# Or rely on a configured ~/.aws/ instead of putting these here.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
